{
  "name": "tubes-rpll",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace apps/frontend\" \"npm run dev --workspace apps/backend\"",
    "dev:web": "npm run dev --workspace apps/frontend",
    "dev:api": "npm run dev --workspace apps/backend",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspace apps/backend"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.0.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^3.30.0",
    "sequelize-cli": "^6.6.5",
    "vite": "8.0.10"
  }
}
